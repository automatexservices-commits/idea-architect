# Supabase Configuration
SUPABASE_PUBLISHABLE_KEY="your_supabase_key_here"
SUPABASE_URL="https://your-project.supabase.co"
VITE_SUPABASE_PROJECT_ID="your-project-id"
VITE_SUPABASE_PUBLISHABLE_KEY="your_supabase_key_here"
VITE_SUPABASE_URL="https://your-project.supabase.co"

# API Keys
OPENAI_API_KEY=sk-your_openai_key_here
GEMINI_API_KEY=your_gemini_key_here

# Google OAuth Configuration
GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here
# Local dev can usually omit VITE_APP_URL because the app now uses window.location.origin.
# Set this for production or any environment that needs a fixed public origin.
VITE_APP_URL=http://localhost:8080
GOOGLE_REDIRECT_URI=http://localhost:8080/auth/google/callback

# InsForge Configuration
VITE_INSFORGE_BASE_URL="https://your-project.region.insforge.app"
VITE_INSFORGE_ANON_KEY="your_insforge_anon_key_here"

# Optional transactional email provider
# Use this if you want branded account emails, password reset emails, or verification emails outside InsForge defaults.
RESEND_API_KEY="re_your_resend_api_key"
RESEND_FROM_EMAIL="PLANNR <noreply@yourdomain.com>"
RESEND_REPLY_TO="support@yourdomain.com"

# Razorpay Configuration
RAZORPAY_KEY_ID="rzp_live_or_test_key_id"
RAZORPAY_KEY_SECRET="your_razorpay_key_secret"
RAZORPAY_PRO_AMOUNT_INR="49"
RAZORPAY_ENTERPRISE_AMOUNT_INR="150"
RAZORPAY_CUSTOM_AMOUNT_INR="0"
VITE_RAZORPAY_PRO_AMOUNT_INR="49"
VITE_RAZORPAY_ENTERPRISE_AMOUNT_INR="150"
VITE_BILLING_UPI_ID="7984390066@ptyes"
VITE_BILLING_UPI_NAME="PLANNR"
VITE_RAZORPAY_CUSTOM_AMOUNT_INR="0"

# For Production:
# VITE_APP_URL=https://yourdomain.com
# GOOGLE_REDIRECT_URI=https://yourdomain.com/auth/google/callback
